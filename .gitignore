venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# OS / Editor
# =========================
.DS_Store
.vscode/
*.swp

# =========================
# Experimental Runs (NEVER COMMIT)
# =========================
runs/**
!runs/**/.keep
!runs/.keep

# GUI session cache is local operator state.
gui/.cache/**
!gui/.cache/.keep

# =========================
